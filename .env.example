APP_NAME=ApiBrinde
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo

API_VERSION=v1
SITE_BASE_URL=http://localhost:3000
ERP_BASE_URL=http://localhost:3001/api

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=api_brinde
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_SCHEMA=public

ERP_DB_CONNECTION=pgsql
ERP_DB_HOST=127.0.0.1
ERP_DB_PORT=5432
ERP_DB_DATABASE=plataforma_brindes
ERP_DB_USERNAME=postgres
ERP_DB_PASSWORD=postgres
ERP_DB_CHARSET=utf8
ERP_DB_SCHEMA=public
ERP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plataforma_brindes?schema=public

API_MAX_BODY_BYTES=262144
API_PUBLIC_RATE_LIMIT_MAX=120
API_PUBLIC_RATE_LIMIT_WINDOW=60
API_PROTECTED_RATE_LIMIT_MAX=300
API_PROTECTED_RATE_LIMIT_WINDOW=60
API_RATE_LIMIT_STORAGE=storage/rate-limit

API_ADMIN_TOKEN=change-this-admin-token
API_READONLY_TOKEN=change-this-readonly-token

LOG_CHANNEL=file
LOG_LEVEL=debug
LOG_PATH=logs/app.log

ERP_CONTENT_BANNERS_SQL=
ERP_CONTENT_TESTIMONIALS_SQL=
ERP_CONTENT_PROMOTIONS_SQL=
ERP_CONTENT_RELEASES_SQL=
ERP_CONTENT_INSTITUTIONAL_TEXTS_SQL=
